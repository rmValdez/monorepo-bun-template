DATABASE_URL="postgresql://postgres:password@localhost:5433/mydb?schema=public"

BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-change-in-production"

# Bun built-in Redis (bun.sh/docs/api/redis)
REDIS_URL="redis://localhost:6379"

# S3-compatible file storage (optional — remove if not using file uploads)
S3_BUCKET="my-bucket"
S3_REGION="ap-southeast-1"
S3_ENDPOINT="https://ap-southeast-1.digitaloceanspaces.com"
S3_PUBLIC_URL="https://my-bucket.ap-southeast-1.digitaloceanspaces.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
