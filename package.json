{
  "name": "bun-monorepo-template",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "lint": "turbo lint",
    "check": "turbo check",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo run start",
    "setup-local-db": "bun --cwd packages/database db:generate && bun --cwd packages/database prisma migrate reset --force && bun x turbo run db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "better-auth": "^1.6.23",
    "date-fns": "^4.4.0"
  }
}
